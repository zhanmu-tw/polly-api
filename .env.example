# Database
DATABASE_URL="postgresql://polly:polly@localhost:5432/polly?schema=public"

# Server
PORT=3000

# API Keys
# API_KEY=        # Full access (read + write)
# GET_API_KEY=    # Read-only access (GET endpoints only)

# Docker Compose overrides
POSTGRES_USER=polly
POSTGRES_PASSWORD=polly
POSTGRES_DB=polly
API_PORT=3000
DB_PORT=5432
